# Enforce LF line endings for text files
* text=auto eol=lf

# Squirrel scripts
*.nut text eol=lf

# Configuration and data files
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.xml text eol=lf

# Shell scripts
*.sh text eol=lf

# Common binary files (do not normalize line endings)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dds binary
*.ogg binary
*.wav binary
*.mp3 binary
